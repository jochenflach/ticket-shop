// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String        @id @default(cuid())
  title       String
  date        DateTime
  description String?
  layoutId    String
  layout      SeatmapLayout @relation(fields: [layoutId], references: [id])
  locks       SeatLock[]
  tickets     Ticket[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SeatmapLayout {
  id        String   @id @default(cuid())
  name      String
  blocks    String   // JSON string of Block[]
  seats     Seat[]
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seat {
  id        String        @id // z.B. "layoutid-A-R1-S1"
  layoutId  String
  layout    SeatmapLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  row       Int
  number    Int
  category  String
  price     Float
  x         Float
  y         Float
  locks     SeatLock[]
  tickets   Ticket[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SeatLock {
  id        String   @id @default(cuid())
  seatId    String
  seat      Seat     @relation(fields: [seatId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  lockedAt  DateTime @default(now())
  lockedBy  String   // Session ID or Seller PIN/ID

  @@unique([seatId, eventId])
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  customerEmail   String
  totalAmount     Float
  status          String   // 'PENDING', 'PAID', 'CANCELLED'
  source          String   // 'CUSTOMER' or 'SELLER'
  stripeSessionId String?  @unique
  promoCodeId     String?
  promoCode       PromoCode? @relation(fields: [promoCodeId], references: [id])
  discountAmount  Float?     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tickets         Ticket[]
}

model Ticket {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seatId      String
  seat        Seat      @relation(fields: [seatId], references: [id])
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType  String    @default("NORMAL") // 'NORMAL', 'STUDENT', 'CHILD', 'FREE'
  pricePaid   Float     @default(0.0)      // Actual price paid after discounts/reductions
  ticketCode  String    @unique // Code for scanning (e.g. random token)
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([seatId, eventId])
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. "EARLYBIRD"
  type        String   // "PERCENT" or "FIXED"
  value       Float    // e.g. 10.0 for 10% or 5.0 for 5 €
  isActive    Boolean  @default(true)
  maxUses     Int?     // Limit on number of redemptions
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}
